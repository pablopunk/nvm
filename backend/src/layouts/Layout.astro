---
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/app.css';

interface Props {
  title: string;
  width?: 'default' | 'wide' | 'narrow';
}

const { title, width = 'default' } = Astro.props;
const containerClass = width === 'wide' ? 'container container--wide' : width === 'narrow' ? 'container container--narrow' : 'container';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body>
    <main class={containerClass}>
      <slot />
    </main>
    <CookieBanner />
    <footer class="site-footer" style="text-align:center;padding:32px 16px;opacity:0.6;font-size:13px">
      <nav style="display:flex;gap:16px;justify-content:center">
        <a href="/terms">Terms</a>
        <a href="/privacy">Privacy</a>
        <a href="/refund">Refunds</a>
        <a href="https://github.com/pablopunk/nvm">GitHub</a>
      </nav>
    </footer>
    <script>
      document.addEventListener('click', (event) => {
        const target = event.target as Element;
        document.querySelectorAll<HTMLDetailsElement>('details.dropdown[open]').forEach((el) => {
          if (!el.contains(target)) el.open = false;
        });
      });
      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        document.querySelectorAll<HTMLDetailsElement>('details.dropdown[open]').forEach((el) => { el.open = false; });
      });
    </script>
  </body>
</html>
