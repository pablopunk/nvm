<div id="cookie-banner" class="cookie-banner" style="display:none">
  <p>This site uses anonymous usage analytics. <strong>No personal data</strong> is collected or shared.</p>
  <div class="cookie-banner__buttons">
    <button id="cookie-banner-allow" class="button button--primary">Allow</button>
    <button id="cookie-banner-decline" class="button">Decline</button>
  </div>
</div>

<script is:inline>
  (function () {
    var consent = localStorage.getItem('gc-consent');
    if (consent === 'accepted') {
      var gcScript = document.createElement('script');
      gcScript.setAttribute('data-goatcounter', '/goat');
      gcScript.async = true;
      gcScript.src = '/count.js';
      document.head.appendChild(gcScript);
      return;
    }
    if (consent === 'declined') return;

    var banner = document.getElementById('cookie-banner');
    if (!banner) return;
    banner.style.display = '';

    var injectGoatcounter = function () {
      localStorage.setItem('gc-consent', 'accepted');
      banner.style.display = 'none';
      var gcScript = document.createElement('script');
      gcScript.setAttribute('data-goatcounter', '/goat');
      gcScript.async = true;
      gcScript.src = '/count.js';
      document.head.appendChild(gcScript);
    };

    var decline = function () {
      localStorage.setItem('gc-consent', 'declined');
      banner.style.display = 'none';
    };

    document.getElementById('cookie-banner-allow')?.addEventListener('click', injectGoatcounter);
    document.getElementById('cookie-banner-decline')?.addEventListener('click', decline);
  })();
</script>

<style is:inline>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    padding: 12px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    z-index: 1000;
    flex-wrap: wrap;
  }
  .cookie-banner p {
    margin: 0;
    font-size: 13px;
    color: var(--text-secondary);
  }
  .cookie-banner__buttons {
    display: flex;
    gap: 8px;
  }
</style>
