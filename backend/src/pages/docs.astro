  <section class="page-hero">
    <h1>Documentation</h1>
    <p>Install Nevermind on your desktop, learn the command palette, and build your own extensions.</p>
  </section>

  <div class="docs-layout">
    <nav class="docs-sidebar" aria-label="Docs navigation">
      <span class="docs-sidebar__section">Getting started</span>
