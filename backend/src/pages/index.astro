---
import { Download } from '@lucide/astro';
import LandingAccount from '../components/LandingAccount.astro';
import Layout from '../layouts/Layout.astro';
---
<Layout title="Nevermind" width="wide" showHeader={false}>
  <div class="landing-shell">
    <header class="landing-nav" aria-label="Primary navigation">
      <a class="landing-brand" href="/" aria-label="Nevermind home">
        <img src="/icon.png" alt="" class="landing-brand__icon" />
        <span>Nevermind</span>
      </a>
      <nav class="landing-nav__links" aria-label="Product links">
        <a href="/pricing">Pricing</a>
        <a href="/docs">Docs</a>
        <a href="https://github.com/pablopunk/nvm/releases">Releases</a>
      </nav>
      <LandingAccount placement="nav" server:defer>
        <a class="button" href="/api/auth/signin" slot="fallback">Sign in</a>
      </LandingAccount>
    </header>

    <section class="landing-hero">
      <div class="landing-hero__copy">
        <h1 class="landing-hero__title">
          <img src="/wordmark.png" alt="Nevermind" class="landing-wordmark" />
        </h1>
        <p class="landing-hero__eyebrow">AI-native command palette for macOS, Windows & Linux</p>
        <p class="landing-hero__lede">
          A command palette that builds itself. Tell it what you need — a screenshot tool, a camera overlay, a clipboard search — and it writes the extension on the spot. Free to use. No coding required.
        </p>
        <div class="landing-actions">
          <a class="button button--primary button--lg" href="https://github.com/pablopunk/nvm/releases">
            <Download size={16} /> Download for free
          </a>
          <a class="button button--ghost" href="/docs">Read the docs →</a>
        </div>
        <form class="waitlist-form" id="waitlist-form">
          <label for="waitlist-email">Join the AI waitlist</label>
          <div class="waitlist-form__row">
            <input id="waitlist-email" name="email" type="email" class="input waitlist-form__input" autocomplete="email" required placeholder="you@example.com" />
            <input name="website" tabindex="-1" autocomplete="off" aria-hidden="true" class="waitlist-form__trap" />
            <button class="button" type="submit">Join waitlist</button>
          </div>
          <small id="waitlist-status" class="muted">We’ll email you if access opens up.</small>
        </form>
      </div>

      <figure class="landing-screenshot">
        <img src="/screenshot.jpg" alt="Nevermind command palette showing AI-built Screenshot and Open Camera extensions" />
        <figcaption>
          The screenshot and camera tools above were created by telling Nevermind what to build — not by writing code.
        </figcaption>
      </figure>
    </section>
  </div>
  <script is:inline>
    const form = document.getElementById('waitlist-form');
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const status = document.getElementById('waitlist-status');
      const response = await fetch('/api/waitlist', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(Object.fromEntries(new FormData(form))) });
      status.textContent = response.ok ? 'If eligible, we’ll email you.' : 'The waitlist is temporarily closed. Please try again later.';
      if (response.ok) form.querySelector('button')?.setAttribute('disabled', 'true');
    });
  </script>
</Layout>
