---
import { Download } from '@lucide/astro';
import LandingAccount from '../components/LandingAccount.astro';
import Layout from '../layouts/Layout.astro';
---
<Layout title="Nevermind" width="wide" showHeader={false}>
  <div class="landing-shell">
    <header class="landing-nav" aria-label="Primary navigation">
      <a class="landing-brand" href="/" aria-label="Nevermind home">
        <img src="/icon.png" alt="" class="landing-brand__icon" />
        <span>Nevermind</span>
      </a>
      <nav class="landing-nav__links" aria-label="Product links">
        <a href="/pricing">Pricing</a>
        <a href="/docs">Docs</a>
        <a href="https://github.com/pablopunk/nvm/releases">Releases</a>
      </nav>
      <LandingAccount placement="nav" server:defer>
        <a class="button" href="/api/auth/signin" slot="fallback">Sign in</a>
      </LandingAccount>
    </header>

    <section class="landing-hero">
      <div class="landing-hero__copy">
        <p class="landing-hero__eyebrow">AI-native command palette for macOS, Windows & Linux</p>
        <h1 class="landing-hero__title">Extend your desktop with one sentence.</h1>
        <p class="landing-hero__lede">
          Nevermind is a command palette that builds itself. Tell it what you need — a screenshot tool, a camera overlay, a clipboard search — and it writes the extension on the spot. Free to use. No coding required.
        </p>
        <div class="landing-actions">
          <a class="button button--primary button--lg" href="https://github.com/pablopunk/nvm/releases">
            <Download size={16} /> Download for free
          </a>
          <a class="button button--ghost" href="/docs">Read the docs →</a>
        </div>
      </div>

      <figure class="landing-screenshot">
        <img src="/screenshot.jpg" alt="Nevermind command palette showing AI-built Screenshot and Open Camera extensions" />
        <figcaption>
          The screenshot and camera tools above were created by telling Nevermind what to build — not by writing code.
        </figcaption>
      </figure>
    </section>

    <section class="landing-features">
      <div class="landing-feature">
        <h3>Extend</h3>
        <p>Describe any tool you need and Nevermind builds it as a local TypeScript extension. Screenshot, camera, image grid — whatever you ask for.</p>
      </div>
      <div class="landing-feature">
        <h3>Build</h3>
        <p>Go back and tweak. Each extension keeps a chat history so you can iterate on UI, behavior, or permissions without starting over.</p>
      </div>
      <div class="landing-feature">
        <h3>Connect</h3>
        <p>Sign in from the desktop app to access cloud AI models. Manage credits, API tokens, and subscriptions from your dashboard.</p>
      </div>
    </section>
  </div>
</Layout>
