---
import { eq } from 'drizzle-orm';
import { getSessionFromCookies } from '../lib/workos';
import { db } from '../db/client';
import { users } from '../db/schema';
import { getBalance } from '../lib/users';
import { listApiTokens } from '../lib/tokens';

const session = await getSessionFromCookies(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/api/auth/signin?return_to=/profile');

const [user] = await db.select().from(users).where(eq(users.workosUserId, session.user.id)).limit(1);
const balance = user ? await getBalance(user.id) : 0;
const tokens = user ? await listApiTokens(user.id) : [];
const isAdmin = user?.role === 'admin';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<title>Nevermind · Profile</title>
	</head>
	<body>
		<nav>
			<a href="/profile">Profile</a>
			{isAdmin && <> · <a href="/admin">Admin</a></>}
		</nav>
		<h1>Profile</h1>
		<p>Email: {user?.email}</p>
		<p>Plan: {user?.plan}</p>
		<p>Role: {user?.role}</p>
		<p>Balance: <strong>{balance}</strong> credits</p>
		<form method="post" action="/api/auth/signout">
			<button type="submit">Sign out</button>
		</form>

		<h2>API tokens</h2>
		<p>Use these in the desktop app or to call the API directly. The full token is shown only once.</p>
		<form id="create-token-form">
			<input type="text" name="name" placeholder="Token name (e.g. My Mac)" required />
			<button type="submit">Create token</button>
		</form>
		<pre id="new-token" style="display:none; background:#eef; padding:8px;"></pre>
		<ul id="token-list">
			{tokens.map((t) => (
				<li data-id={t.id}>
					<code>{t.prefix}…</code> · {t.name} · created {new Date(t.createdAt).toLocaleString()}
					{t.lastUsedAt ? ` · last used ${new Date(t.lastUsedAt).toLocaleString()}` : ' · never used'}
					<button class="revoke" data-id={t.id}>Revoke</button>
				</li>
			))}
		</ul>

		<script is:inline>
			document.getElementById('create-token-form').addEventListener('submit', async (e) => {
				e.preventDefault();
				const fd = new FormData(e.target);
				const res = await fetch('/api/tokens', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ name: fd.get('name') }),
				});
				if (!res.ok) return alert('Failed to create token');
				const data = await res.json();
				const el = document.getElementById('new-token');
				el.style.display = 'block';
				el.textContent = `Save this token now — it will not be shown again:\n${data.token}`;
				setTimeout(() => location.reload(), 100);
			});
			document.querySelectorAll('.revoke').forEach((btn) => {
				btn.addEventListener('click', async () => {
					if (!confirm('Revoke this token?')) return;
					await fetch(`/api/tokens/${btn.dataset.id}`, { method: 'DELETE' });
					location.reload();
				});
			});
		</script>
	</body>
</html>
