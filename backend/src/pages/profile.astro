---
import Layout from '../layouts/Layout.astro';
import { eq } from 'drizzle-orm';
import { getSessionFromCookies } from '../lib/workos';
import { db } from '../db/client';
import { users, subscriptions } from '../db/schema';
import { billingCatalog, isActiveBillingSubscriptionStatus } from '../lib/billing';
import { ensureMonthlyFreeCredits, getBalances } from '../lib/users';
import { listApiTokens } from '../lib/tokens';

const session = await getSessionFromCookies(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect('/api/auth/signin?return_to=/profile');

const [user] = await db.select().from(users).where(eq(users.workosUserId, session.user.id)).limit(1);
if (user) await ensureMonthlyFreeCredits(user.id);
const balances = user ? await getBalances(user.id) : { free: 0, paid: 0, total: 0 };
const tokens = user ? await listApiTokens(user.id) : [];
const [subscription] = user ? await db.select().from(subscriptions).where(eq(subscriptions.userId, user.id)).limit(1) : [];
const catalog = (() => {
  try { return billingCatalog(); } catch { return { subscriptions: [], topUps: [] }; }
})();
const isAdmin = user?.role === 'admin';
const hasActiveSubscription = subscription ? isActiveBillingSubscriptionStatus(subscription.status) : false;
const canBuyTopUps = hasActiveSubscription;
const billingState = Astro.url.searchParams.get('billing');
---
<Layout title="Nevermind · Profile">
  <nav class="nav">
    <a href="/profile" aria-current="page">Profile</a>
    {isAdmin && <a href="/admin">Admin</a>}
    <span class="spacer"></span>
    <form method="post" action="/api/auth/signout"><button class="button" type="submit">Sign out</button></form>
  </nav>

  <h1>Profile</h1>
  <p class="muted">Account, balance, and API tokens.</p>

  <div class="section stat-grid">
    <div class="stat"><div class="v">{balances.total}</div><div class="l">Credits</div></div>
    <div class="stat"><div class="v">{balances.free}</div><div class="l">Free</div></div>
    <div class="stat"><div class="v">{balances.paid}</div><div class="l">Paid</div></div>
    <div class="stat"><div class="v">{user?.plan}</div><div class="l">Plan</div></div>
  </div>

  <div class="section card">
    <h3>Account</h3>
    <p style="margin:0"><code>{user?.email}</code> · {user?.role}</p>
  </div>

  <div class="section card stack">
    <div>
      <h3>Billing</h3>
      <p class="muted" style="margin:0">
        {subscription ? `${subscription.status} · renews ${new Date(subscription.currentPeriodEnd).toLocaleDateString()}` : 'No active subscription.'}
      </p>
    </div>
    {billingState === 'success' && <p class="status status--ok">Billing updated. Credits may take a moment to appear.</p>}
    {billingState === 'canceled' && <p class="status">Checkout canceled.</p>}
    <div class="row">
      {!hasActiveSubscription && catalog.subscriptions.map((item) => (
        <button class="button button--primary billing-checkout" data-kind="subscription" data-price-id={item.priceId}>
          Subscribe {item.tier} · {item.credits} credits/mo
        </button>
      ))}
      {canBuyTopUps && catalog.topUps.map((item) => (
        <button class="button billing-checkout" data-kind="top_up" data-price-id={item.priceId}>
          Top up · {item.credits} credits
        </button>
      ))}
      {!canBuyTopUps && catalog.topUps.length > 0 && <span class="muted">Top-ups unlock after subscribing to Pro.</span>}
      {user?.stripeCustomerId && (
        <button class={hasActiveSubscription ? 'button button--primary' : 'button'} id="manage-billing" type="button">
          {hasActiveSubscription ? 'Manage subscription' : 'Manage billing'}
        </button>
      )}
      {catalog.subscriptions.length === 0 && catalog.topUps.length === 0 && <span class="muted">Billing is not configured yet.</span>}
    </div>
    <p id="billing-status" class="status" style="margin:0"></p>
  </div>

  <div class="section">
    <h2>API tokens</h2>
    <p class="muted">Use these to call the API directly. The full token is shown only once.</p>
    <form id="create-token-form" class="row" style="margin-bottom:12px;">
      <input class="input" type="text" name="name" placeholder="Token name (e.g. My Mac)" required />
      <button class="button button--primary" type="submit">Create token</button>
    </form>
    <div id="new-token-panel" class="card stack" style="display:none;" role="region" aria-label="New API token">
      <div>
        <h3>Your new API token</h3>
        <p class="muted" style="margin:0;">Save this token now — it will not be shown again.</p>
      </div>
      <pre class="token-value" id="new-token-value"></pre>
      <div id="copy-status" aria-live="polite" class="status"></div>
      <div class="row">
        <button type="button" id="copy-token-btn" class="button button--primary">Copy</button>
        <button type="button" id="close-token-btn" class="button">Close</button>
      </div>
    </div>
    <ul class="list-clean">
      {tokens.map((t) => (
        <li data-id={t.id}>
          <code>{t.prefix}…</code>
          <span>{t.name}</span>
          <span class="muted">· created {new Date(t.createdAt).toLocaleString()}</span>
          <span class="muted">{t.lastUsedAt ? `· last used ${new Date(t.lastUsedAt).toLocaleString()}` : '· never used'}</span>
          <span class="spacer" style="flex:1"></span>
          <button class="button button--danger revoke" data-id={t.id}>Revoke</button>
        </li>
      ))}
      {tokens.length === 0 && <li class="muted">No tokens yet.</li>}
    </ul>
  </div>

  <script is:inline>
    const createTokenForm = document.getElementById('create-token-form');
    const createTokenBtn = createTokenForm.querySelector('button[type="submit"]');
    const createTokenInput = createTokenForm.querySelector('input[name="name"]');
    const newTokenPanel = document.getElementById('new-token-panel');
    const newTokenValue = document.getElementById('new-token-value');
    const copyTokenBtn = document.getElementById('copy-token-btn');
    const closeTokenBtn = document.getElementById('close-token-btn');
    const copyStatus = document.getElementById('copy-status');

    function setPanelVisible(visible) {
      newTokenPanel.style.display = visible ? '' : 'none';
      createTokenInput.disabled = visible;
      createTokenBtn.disabled = visible;
    }

    let undisclosedToken = null;

    function beforeUnloadHandler(e) {
      e.preventDefault();
      e.returnValue = '';
    }

    function dismissTokenPanel() {
      window.removeEventListener('beforeunload', beforeUnloadHandler);
      undisclosedToken = null;
      newTokenValue.textContent = '';
      setPanelVisible(false);
      location.reload();
    }

    function copyTokenToClipboard() {
      if (!undisclosedToken) return;
      copyStatus.textContent = '';
      copyStatus.className = 'status';
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(undisclosedToken).then(() => {
          copyStatus.textContent = 'Copied to clipboard.';
          copyStatus.className = 'status status--ok';
        }).catch(() => {
          fallbackCopyToken();
        });
      } else {
        fallbackCopyToken();
      }
    }

    function fallbackCopyToken() {
      const ta = document.createElement('textarea');
      ta.value = undisclosedToken;
      ta.style.position = 'fixed';
      ta.style.left = '-9999px';
      document.body.appendChild(ta);
      ta.select();
      try {
        document.execCommand('copy');
        copyStatus.textContent = 'Copied to clipboard.';
        copyStatus.className = 'status status--ok';
      } catch {
        copyStatus.textContent = 'Could not copy automatically. Please select and copy the token manually.';
        copyStatus.className = 'status status--err';
      } finally {
        document.body.removeChild(ta);
      }
    }

    createTokenForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (undisclosedToken) return;
      const fd = new FormData(e.target);
      const res = await fetch('/api/tokens', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: fd.get('name') }),
      });
      if (!res.ok) {
        alert('Failed to create token');
        return;
      }
      const data = await res.json();
      undisclosedToken = data.token;
      newTokenValue.textContent = data.token;
      setPanelVisible(true);
      copyStatus.textContent = '';
      copyStatus.className = 'status';
      window.addEventListener('beforeunload', beforeUnloadHandler);
      copyTokenBtn.focus();
    });

    copyTokenBtn.addEventListener('click', copyTokenToClipboard);
    closeTokenBtn.addEventListener('click', dismissTokenPanel);
    const billingStatus = document.getElementById('billing-status');
    async function redirectFromBillingEndpoint(path, body) {
      billingStatus.textContent = 'Opening Stripe…';
      const res = await fetch(path, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: body ? JSON.stringify(body) : undefined,
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.url) {
        billingStatus.textContent = data.error?.message || 'Unable to open billing right now.';
        billingStatus.className = 'status status--err';
        return;
      }
      location.href = data.url;
    }
    document.querySelectorAll('.billing-checkout').forEach((btn) => {
      btn.addEventListener('click', () => redirectFromBillingEndpoint('/api/billing/checkout', {
        kind: btn.dataset.kind,
        priceId: btn.dataset.priceId,
      }));
    });
    document.getElementById('manage-billing')?.addEventListener('click', () => redirectFromBillingEndpoint('/api/billing/portal'));

    document.querySelectorAll('.revoke').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!confirm('Revoke this token?')) return;
        await fetch(`/api/tokens/${btn.dataset.id}`, { method: 'DELETE' });
        location.reload();
      });
    });
  </script>
</Layout>
