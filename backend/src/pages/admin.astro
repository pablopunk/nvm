---
import Layout from '../layouts/Layout.astro';
import Combobox from '../components/Combobox.astro';
import { getCurrentUser, isAdmin } from '../lib/admin';
import { getModelRoute, listKnownProviders, modelRouteToRef, ModelNotConfiguredError, type ModelRouteSlot } from '../lib/settings';
import { listModelsForProvider } from '../lib/pricing';
import { CREDIT_USD } from '../lib/cost';

const user = await getCurrentUser(Astro.request);
if (!user) return Astro.redirect('/api/auth/signin?return_to=/admin');
if (!isAdmin(user)) return new Response('Forbidden', { status: 403 });

const safeModelRef = async (slot: ModelRouteSlot) => {
  try { return modelRouteToRef(await getModelRoute(slot)); } catch (err) { if (err instanceof ModelNotConfiguredError) return null; throw err; }
};
const activeModelRef = await safeModelRef('paid');
const freeModelRef = await safeModelRef('free');
const smartModelRef = await safeModelRef('smart');
const fastModelRef = await safeModelRef('fast');
const modelOptions = (await Promise.all(listKnownProviders().map(async (provider) => {
  const models = await listModelsForProvider(provider);
  return models.map((modelId) => ({ provider, modelId, ref: modelRouteToRef({ provider, modelId }) }));
}))).flat();
---
<Layout title="Nevermind · Admin" width="wide">
  <Combobox />
  <nav class="nav">
    <a href="/profile">Profile</a>
    <a href="/admin" aria-current="page">Admin</a>
    <span class="spacer"></span>
    <span class="muted"><code>{user.email}</code></span>
  </nav>

  <h1>Admin</h1>
  <p class="muted">Provider routing, models, and usage.</p>
  <span id="admin-config" data-credit-usd={CREDIT_USD} hidden></span>

  <div class="section card">
    <h3>Models</h3>
    <p class="muted">Each selector includes provider and model. Extensions can call <code>ctx.ai(prompt, 'smart')</code> or <code>ctx.ai(prompt, 'fast')</code>; unset smart/fast routes fall back to pro/free.</p>
    <div class="stack">
      <div class="row">
        <label class="field field--inline">Smart →
          <select id="model-select-smart" class="input combo autosave" data-purpose="smart">
            {modelOptions.map((m) => <option value={m.ref} selected={m.ref === smartModelRef}>{m.ref}</option>)}
          </select>
        </label>
        <span class="status" data-status-for="model-select-smart"></span>
      </div>
      <div class="row">
        <label class="field field--inline">Fast →
          <select id="model-select-fast" class="input combo autosave" data-purpose="fast">
            {modelOptions.map((m) => <option value={m.ref} selected={m.ref === fastModelRef}>{m.ref}</option>)}
          </select>
        </label>
        <span class="status" data-status-for="model-select-fast"></span>
      </div>
      <div class="row">
        <label class="field field--inline">Pro default →
          <select id="model-select-paid" class="input combo autosave" data-purpose="paid">
            {modelOptions.map((m) => <option value={m.ref} selected={m.ref === activeModelRef}>{m.ref}</option>)}
          </select>
        </label>
        <span class="status" data-status-for="model-select-paid"></span>
      </div>
      <div class="row">
        <label class="field field--inline">Free default →
          <select id="model-select-free" class="input combo autosave" data-purpose="free">
            {modelOptions.map((m) => <option value={m.ref} selected={m.ref === freeModelRef}>{m.ref}</option>)}
          </select>
        </label>
        <span class="status" data-status-for="model-select-free"></span>
      </div>
    </div>
  </div>

  <div class="section card">
    <h3>Providers</h3>
    <p class="muted">Toggle providers on/off. Disabled providers are skipped during failover. Click Probe to test connectivity.</p>
    <table class="table" id="providers-table">
      <thead><tr><th>Provider</th><th>Enabled</th><th>Priority</th><th>Health</th><th></th></tr></thead>
      <tbody><tr><td colspan="5" class="muted">Loading…</td></tr></tbody>
    </table>
  </div>

  <div class="section card">
    <h2>Last 30 days</h2>
    <div class="stat-grid" id="timeseries-grid">
      <div class="stat"><div class="v" id="ts-requests">…</div><div class="l">Requests/day</div><svg class="spark" id="ts-requests-spark" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
      <div class="stat"><div class="v" id="ts-credits">…</div><div class="l">Credits/day</div><svg class="spark" id="ts-credits-spark" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
      <div class="stat"><div class="v" id="ts-errors">…</div><div class="l">Error rate</div><svg class="spark" id="ts-errors-spark" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
      <div class="stat"><div class="v" id="ts-p95">…</div><div class="l">Latency p95 (ms)</div><svg class="spark" id="ts-p95-spark" viewBox="0 0 100 24" preserveAspectRatio="none"></svg></div>
    </div>
  </div>

  <div class="section">
    <h2>System stats</h2>
    <div class="stat-grid" id="stats"><div class="stat"><div class="v">…</div><div class="l">loading</div></div></div>
    <div style="margin-top:16px;" class="card">
      <h3>Usage by model</h3>
      <table class="table" id="by-model">
        <thead><tr><th>Provider</th><th>Model</th><th>Requests</th><th>Input tok</th><th>Output tok</th><th>Credits</th><th>Raw cost</th><th>Retail value</th></tr></thead>
        <tbody></tbody>
      </table>
    </div>
  </div>

  <div class="section card">
    <h2>Audit log</h2>
    <table class="table" id="audit-table">
      <thead><tr><th>When</th><th>Actor</th><th>Action</th><th>Target</th><th>Meta</th></tr></thead>
      <tbody><tr><td colspan="5" class="muted">Loading…</td></tr></tbody>
    </table>
  </div>

  <div class="section card">
    <h2>Users</h2>
    <table class="table" id="users-table">
      <thead><tr>
        <th>Email</th><th>Role</th><th>Plan</th><th>Balance</th>
        <th>Requests</th><th>Spent</th><th>Last model</th><th>Last used</th><th>Joined</th><th></th>
      </tr></thead>
      <tbody></tbody>
    </table>
  </div>

  <script is:inline>
    function esc(str) {
      if (!str) return '';
      return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    async function loadStats() {
      const res = await fetch('/api/admin/stats');
      const s = await res.json();
      document.getElementById('stats').innerHTML = `
        <div class="stat"><div class="v">${s.users}</div><div class="l">Users</div></div>
        <div class="stat"><div class="v">${s.usage.requests}</div><div class="l">AI requests</div></div>
        <div class="stat"><div class="v">${s.usage.inputTokens + s.usage.outputTokens}</div><div class="l">Total tokens</div></div>
        <div class="stat"><div class="v">${s.credits.spent} / ${s.credits.granted}</div><div class="l">Credits spent / granted</div></div>
      `;
      const tbody = document.querySelector('#by-model tbody');
      const creditUsd = Number(document.getElementById('admin-config')?.dataset.creditUsd || '0.01');
      tbody.innerHTML = s.byModel.map((r) => {
        const usd = Number(r.upstreamCostMicrocents || 0) / 1e8;
        const collectedUsd = (r.costCredits || 0) * creditUsd;
        return `<tr><td>${esc(r.provider) || '—'}</td><td><code>${esc(r.model)}</code></td><td>${r.requests}</td><td>${r.inputTokens}</td><td>${r.outputTokens}</td><td>${r.costCredits}</td><td>$${usd.toFixed(4)}</td><td>$${collectedUsd.toFixed(4)}</td></tr>`;
      }).join('') || '<tr><td colspan="8" class="muted">No usage yet</td></tr>';
    }
    function statusEl(selectId) {
      return document.querySelector(`[data-status-for="${selectId}"]`);
    }
    function setState(el, state) {
      const map = {
        idle: { cls: 'status', text: '' },
        saving: { cls: 'status', text: 'Saving…' },
        saved: { cls: 'status status--ok', text: 'Saved ✓' },
        error: { cls: 'status status--err', text: 'Failed' },
      };
      const s = map[state];
      el.className = s.cls;
      el.textContent = s.text;
    }
    async function autosave(select, fetcher) {
      const status = statusEl(select.id);
      const ts = select.tomselect;
      setState(status, 'saving');
      ts ? ts.disable() : (select.disabled = true);
      try {
        const res = await fetcher(select.value);
        setState(status, res.ok ? 'saved' : 'error');
      } catch {
        setState(status, 'error');
      } finally {
        ts ? ts.enable() : (select.disabled = false);
        setTimeout(() => setState(status, 'idle'), 1500);
      }
    }
    function wireAutosave() {
      document.querySelectorAll('.autosave').forEach((el) => {
        el.addEventListener('change', () => autosave(el, (model) => fetch('/api/admin/model', {
          method: 'PUT', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ modelRef: model, purpose: el.dataset.purpose || el.dataset.tier }),
        })));
      });
    }
    wireAutosave();
    async function loadUsers() {
      const res = await fetch('/api/admin/users');
      const { users } = await res.json();
      const tbody = document.querySelector('#users-table tbody');
      const iconMore = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>';
      const iconPlus = '<svg class="dropdown__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>';
      const iconShield = '<svg class="dropdown__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-8 9-4.5-1.5-8-4-8-9V5l8-3 8 3z"/></svg>';
      tbody.innerHTML = users.map((u) => `
        <tr>
          <td>${esc(u.email)}</td>
          <td>${esc(u.role)}</td>
          <td>${esc(u.plan)}</td>
          <td>${u.balance}</td>
          <td>${u.requests}</td>
          <td>${u.spent}</td>
          <td>${u.lastModel ? `<code>${esc(u.lastModel)}</code>` : '—'}</td>
          <td>${u.lastUsedAt ? new Date(u.lastUsedAt).toLocaleString() : '—'}</td>
          <td>${new Date(u.createdAt).toLocaleDateString()}</td>
          <td>
            <details class="dropdown">
              <summary class="dropdown__trigger" aria-label="Actions">${iconMore}</summary>
              <div class="dropdown__menu">
                <button type="button" class="dropdown__item grant-credits" data-id="${u.id}" data-email="${esc(u.email)}">${iconPlus}Grant credits</button>
                <div class="dropdown__separator"></div>
                <button type="button" class="dropdown__item toggle-role" data-id="${u.id}" data-role="${u.role === 'admin' ? 'user' : 'admin'}">${iconShield}${u.role === 'admin' ? 'Demote to user' : 'Promote to admin'}</button>
              </div>
            </details>
          </td>
        </tr>
      `).join('');
      tbody.querySelectorAll('.toggle-role').forEach((btn) => {
        btn.addEventListener('click', async () => {
          await fetch('/api/admin/admins', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: btn.dataset.id, role: btn.dataset.role }),
          });
          loadUsers();
        });
      });
      tbody.querySelectorAll('.grant-credits').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const raw = prompt(`Grant credits to ${btn.dataset.email}\nPositive to add, negative to deduct. Append " free" to grant to the free pool.\nExample: 1000  or  500 free`);
          if (!raw) return;
          const [amountStr, kindRaw] = raw.trim().split(/\s+/);
          const delta = Number(amountStr);
          const kind = kindRaw === 'free' ? 'free' : 'paid';
          if (!Number.isFinite(delta) || !delta) return alert('Invalid amount');
          const res = await fetch('/api/admin/credits', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: btn.dataset.id, delta, kind }),
          });
          if (res.ok) loadUsers();
          else alert('Failed to grant credits');
        });
      });
    }
    async function loadAudit() {
      const res = await fetch('/api/admin/audit?limit=50');
      const { entries } = await res.json();
      const tbody = document.querySelector('#audit-table tbody');
      if (!entries.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="muted">No audit entries yet</td></tr>';
        return;
      }
      tbody.innerHTML = entries.map((e) => `
        <tr>
          <td>${new Date(e.createdAt).toLocaleString()}</td>
          <td>${e.actorEmail ? esc(e.actorEmail) : '—'}</td>
          <td><code>${esc(e.action)}</code></td>
          <td>${e.targetType ? `${esc(e.targetType)}:${e.targetId ? esc(e.targetId) : '—'}` : '—'}</td>
          <td><code>${e.meta ? esc(JSON.stringify(e.meta)) : ''}</code></td>
        </tr>
      `).join('');
    }
    function sparkPath(values) {
      if (!values.length) return '';
      const max = Math.max(1, ...values);
      const step = 100 / Math.max(1, values.length - 1);
      return values.map((v, i) => `${i === 0 ? 'M' : 'L'}${(i * step).toFixed(2)},${(24 - (v / max) * 22 - 1).toFixed(2)}`).join(' ');
    }
    function renderSpark(svgId, values) {
      const el = document.getElementById(svgId);
      if (!el) return;
      el.innerHTML = `<path d="${sparkPath(values)}" fill="none" stroke="var(--accent-9, currentColor)" stroke-width="1.5"/>`;
    }
    async function loadTimeseries() {
      const res = await fetch('/api/admin/timeseries?days=30');
      const { series } = await res.json();
      const requests = series.map((s) => s.requests);
      const credits = series.map((s) => s.credits);
      const errors = series.map((s) => s.errors);
      const p95 = series.map((s) => s.p95 ?? 0);
      const totReq = requests.reduce((a, b) => a + b, 0);
      const totErr = errors.reduce((a, b) => a + b, 0);
      const errRate = totReq ? ((totErr / totReq) * 100).toFixed(2) + '%' : '0%';
      document.getElementById('ts-requests').textContent = requests.at(-1) ?? 0;
      document.getElementById('ts-credits').textContent = credits.at(-1) ?? 0;
      document.getElementById('ts-errors').textContent = errRate;
      document.getElementById('ts-p95').textContent = p95.at(-1) ? Math.round(p95.at(-1)) : '—';
      renderSpark('ts-requests-spark', requests);
      renderSpark('ts-credits-spark', credits);
      renderSpark('ts-errors-spark', errors);
      renderSpark('ts-p95-spark', p95);
    }
    async function loadProviders() {
      const res = await fetch('/api/admin/provider');
      const { providers } = await res.json();
      const tbody = document.querySelector('#providers-table tbody');
      tbody.innerHTML = providers.map((p) => `
        <tr>
          <td><code>${esc(p.id)}</code> <span class="muted">${esc(p.displayName)}</span></td>
          <td>
            <label class="toggle">
              <input type="checkbox" class="provider-toggle" data-id="${p.id}" ${p.enabled === 'true' ? 'checked' : ''}>
              <span class="toggle__slider"></span>
            </label>
          </td>
          <td>${p.priority}</td>
          <td><span class="probe-status" data-provider="${p.id}">—</span></td>
          <td><button type="button" class="btn btn--sm probe-btn" data-id="${p.id}">Probe</button></td>
        </tr>
      `).join('');

      tbody.querySelectorAll('.provider-toggle').forEach((cb) => {
        cb.addEventListener('change', async () => {
          const res = await fetch('/api/admin/provider', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: cb.dataset.id, enabled: cb.checked }),
          });
          if (!res.ok) cb.checked = !cb.checked;
        });
      });

      tbody.querySelectorAll('.probe-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const statusEl = document.querySelector(`.probe-status[data-provider="${btn.dataset.id}"]`);
          statusEl.textContent = '…';
          statusEl.className = 'probe-status';
          btn.disabled = true;
          try {
            const res = await fetch(`/api/admin/probe/${btn.dataset.id}`);
            const r = await res.json();
            if (r.ok) {
              statusEl.textContent = `✓ ${r.status} ${r.latencyMs}ms`;
              statusEl.className = 'probe-status status--ok';
            } else {
              statusEl.textContent = `✗ ${r.error || r.status || 'unreachable'}`;
              statusEl.className = 'probe-status status--err';
            }
          } catch (err) {
            statusEl.textContent = '✗ error';
            statusEl.className = 'probe-status status--err';
          } finally {
            btn.disabled = false;
          }
        });
      });
    }
    loadStats();
    loadUsers();
    loadAudit();
    loadTimeseries();
    loadProviders();
  </script>
</Layout>
