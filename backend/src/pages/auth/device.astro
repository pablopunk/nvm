---
import Layout from '../../layouts/Layout.astro';
import { eq, and, gt } from 'drizzle-orm';
import { getSessionFromCookies } from '../../lib/workos';
import { db } from '../../db/client';
import { users, deviceCodes } from '../../db/schema';

const code = (Astro.url.searchParams.get('code') ?? '').trim();
const session = await getSessionFromCookies(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect(`/api/auth/signin?return_to=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`);

const [user] = await db.select().from(users).where(eq(users.workosUserId, session.user.id)).limit(1);
const [row] = code
  ? await db.select().from(deviceCodes).where(and(eq(deviceCodes.code, code), gt(deviceCodes.expiresAt, new Date()))).limit(1)
  : [];

const state = !code
  ? 'missing'
  : !row
    ? 'expired'
    : row.approvedAt
      ? 'already'
      : 'ready';
---
<Layout title="Nevermind · Connect device" width="narrow">
  <h1>Connect a device</h1>
  <p class="muted">Signed in as <code>{user?.email}</code></p>

  <div class="section card">
    {state === 'missing' && <p>Missing device code in URL.</p>}
    {state === 'expired' && <p>This code has expired. Open the Nevermind app and try again.</p>}
    {state === 'already' && <p>This device is already approved — return to the app.</p>}
    {state === 'ready' && (
      <>
        <p>Approve <strong>{row?.deviceLabel}</strong> to sign it into your Nevermind account.</p>
        <form id="approve-form" class="stack">
          <label class="field">Device label
            <input class="input" name="label" value={row?.deviceLabel} />
          </label>
          <div class="row">
            <button class="button button--primary" type="submit">Approve device</button>
            <span id="approve-status" class="status"></span>
          </div>
        </form>
        <div class="section" style="margin-top:16px">
          <p class="muted">Or open directly in the desktop app:</p>
          <a id="deep-link" class="button" href={`nvm://auth?code=${code}&base_url=${encodeURIComponent(new URL(Astro.request.url).origin)}`}>
            Open in Nevermind
          </a>
          <p id="deep-link-fallback" style="display:none" class="muted">
            The app didn't open automatically. Copy this code and paste it in Nevermind via ⌘K → "Log in":<br/>
            <code>{code}</code>
            <button class="button" id="copy-code-btn" style="margin-top:8px">Copy code</button>
          </p>
        </div>
        <script is:inline define:vars={{ code }}>
          var deepLinkEl = document.getElementById('deep-link');
          var fallbackEl = document.getElementById('deep-link-fallback');
          var copyBtn = document.getElementById('copy-code-btn');

          if (deepLinkEl) {
            deepLinkEl.addEventListener('click', function (e) {
              var didBlur = false;
              var onBlur = function () { didBlur = true; };
              window.addEventListener('blur', onBlur, { once: true });
              setTimeout(function () {
                window.removeEventListener('blur', onBlur);
                if (!didBlur && fallbackEl) {
                  fallbackEl.style.display = '';
                }
              }, 1500);
            });
          }
          if (copyBtn) {
            copyBtn.addEventListener('click', function () {
              navigator.clipboard.writeText(code);
              copyBtn.textContent = 'Copied!';
            });
          }

          document.getElementById('approve-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            var label = e.target.elements.label.value;
            var status = document.getElementById('approve-status');
            status.className = 'status';
            status.textContent = 'Approving…';
            var res = await fetch('/api/auth/device/approve', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ code, label }),
            });
            if (res.ok) {
              status.className = 'status status--ok';
              status.textContent = 'Approved — return to the app.';
            } else {
              status.className = 'status status--err';
              status.textContent = await res.text();
            }
          });
        </script>
      </>
    )}
  </div>
</Layout>
