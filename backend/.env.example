DATABASE_URL=postgres://...

WORKOS_API_KEY=sk_...
WORKOS_CLIENT_ID=client_...
WORKOS_REDIRECT_URI=http://localhost:4321/api/auth/callback
WORKOS_COOKIE_PASSWORD=at-least-32-chars-of-random-secret-here

# v2 auth gateway. Keep state/grant/session keys and Redis identities separate.
GATEWAY_STATE_KEY=at-least-32-chars-of-random-secret-here
GATEWAY_STATE_REDIS_URL=
GATEWAY_STATE_REDIS_TOKEN=
PREVIEW_GATEWAY_ORIGIN=https://nvm.fyi
PRODUCTION_ORIGIN=https://nvm.fyi
PREVIEW_START_KEY=at-least-32-chars-of-random-secret-here
PREVIEW_GRANT_REDIS_URL=
PREVIEW_GRANT_REDIS_TOKEN=
PREVIEW_REDIS_URL=
PREVIEW_REDIS_TOKEN=
PREVIEW_SESSION_KEY=at-least-32-chars-of-random-secret-here
PREVIEW_DATABASE_URL=
PRODUCTION_DATABASE_URL=

PUBLIC_DASHBOARD_URL=http://localhost:4321
DESKTOP_DEEP_LINK_SCHEME=nvm

OPENCODE_API_KEY=...
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
DEFAULT_AI_MODEL=gemini-3-flash

# Credits are user-facing retail units. Defaults make 1 credit ≈ $0.01 retail usage
# with a 5x markup over raw model cost.
CREDIT_USD=0.01
CREDIT_MARKUP=5
MONTHLY_FREE_CREDITS=500

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# JSON arrays or objects keyed by price ID. Values are paid credit grants.
STRIPE_SUBSCRIPTION_TIERS=[{"priceId":"price_monthly","tier":"pro","credits":1000}]
STRIPE_TOP_UP_PACKS=[{"priceId":"price_topup","credits":1000}]
# Single-price fallback envs also work:
# STRIPE_SUBSCRIPTION_PRICE_ID=price_monthly
# STRIPE_SUBSCRIPTION_TIER=pro
# STRIPE_SUBSCRIPTION_CREDITS=1000
# STRIPE_TOP_UP_PRICE_ID=price_topup
# STRIPE_TOP_UP_CREDITS=1000

# Legacy shared Redis variables are not used by the v2 auth gateway.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
MAX_INPUT_TOKENS=100000

SENTRY_DSN=
CRON_SECRET=

NEVERMIND_MIN_DESKTOP_VERSION=0.0.0
NEVERMIND_LATEST_DESKTOP_VERSION=
NEVERMIND_DESKTOP_UPDATE_URL=https://github.com/pablopunk/nvm/releases/latest
# Defaults include active_model_descriptor and proxy_streaming.
# Add comma-list flags or override with JSON rules:
# {"feature_a":true,"active_model_descriptor":{"minDesktopVersion":"0.7.0"},"proxy_streaming":{"rolloutPercent":25}}
NEVERMIND_FEATURE_FLAGS=
# Comma list or JSON booleans, e.g. ai_proxy,ai_streaming,auth_device or {"ai_proxy":true}
NEVERMIND_KILL_SWITCHES=

# strict (default) — reject invalid request bodies with 400.
# warn — log rejected bodies but still process the request (old as‑cast path).
# off — skip validation entirely.
NEVERMIND_VALIDATION_MODE=strict
PUBLIC_WAITLIST_ENABLED=false
INVITE_GATE_ENABLED=false
INVITE_TTL_DAYS=7
INVITE_BULK_CAP=50
INVITE_INTENT_SECRET=
RESEND_API_KEY=
INVITE_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=
