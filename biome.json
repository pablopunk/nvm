{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!backend"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "correctness": {
        "recommended": true,
        "noUnusedFunctionParameters": "off",
        "noUnusedImports": "off",
        "noUnusedVariables": "off",
        "useExhaustiveDependencies": "off",
        "useHookAtTopLevel": "off"
      },
      "suspicious": "warn",
      "style": "warn",
      "a11y": "warn",
      "performance": "warn",
      "complexity": "warn"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "overrides": [
    {
      "include": ["scripts/**", ".agents/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off",
            "useStrictMode": "off"
          },
          "style": {
            "useBlockStatements": "off",
            "noUnusedTemplateLiteral": "off"
          },
          "complexity": {
            "useSimplifiedLogicExpression": "off"
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
