{
  "name": "nvm",
  "version": "0.0.1",
  "description": "Nevermind: an AI-native command palette for your desktop",
  "author": "Pablo Varela",
  "private": true,
  "type": "module",
  "main": "src/electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.check.json",
    "test": "node scripts/check-design-system.cjs && pnpm typecheck",
    "electron": "electron .",
    "electron:dev": "node ./scripts/prepare-dev.cjs && concurrently -k \"pnpm dev\" \"wait-on tcp:127.0.0.1:5173 && ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .\"",
    "dist": "pnpm run dist:mac:arm64",
    "dist:mac": "pnpm run dist:mac:arm64",
    "dist:mac:arm64": "pnpm build && electron-builder --config electron-builder.yml --mac zip --arm64 --publish never",
    "dist:linux": "pnpm run dist:linux:x64",
    "dist:linux:x64": "pnpm build && electron-builder --config electron-builder.yml --linux AppImage deb --x64 --publish never",
    "dist:linux:arm64": "pnpm build && electron-builder --config electron-builder.yml --linux AppImage deb --arm64 --publish never",
    "dist:win:x64": "pnpm build && electron-builder --config electron-builder.yml --win nsis portable --x64 --publish never"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@vitejs/plugin-react": "latest",
    "electron-updater": "^6.3.9",
    "cmdk": "^1.1.1",
    "file-icon": "^6.0.0",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "wait-on": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
